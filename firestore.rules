rules_version = '2';
// AI 생성 큐. 앱(로그인 없음)은 pending 요청 생성 + 자기 doc 구독만.
// 결과(status=done/error·questions)는 맥북 워커가 Admin SDK로만 기록(규칙 우회).
// ⚠️ friend-1 전제: create가 열려 있어 스팸 여지 있음 → 확대 시 App Check로 강화.
service cloud.firestore {
  match /databases/{database}/documents {
    match /gen_requests/{id} {
      // 앱은 pending 요청만 생성(허용 키 고정 — 클라가 done/questions 위조 불가).
      allow create: if request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly(
             ['subjectId', 'yearScope', 'count', 'type', 'status', 'createdAt']);
      // 문서 id(무작위)를 아는 요청자만 결과 구독.
      allow get: if true;
      // 갱신·삭제·목록은 워커(Admin)만.
      allow update, delete, list: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
